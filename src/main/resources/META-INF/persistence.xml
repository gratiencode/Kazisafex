<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="kazisafe-jmx" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>models.Operation</class>
        <class>models.Facture</class>
        <class>models.Destocker</class>
        <class>models.Role</class>
        <class>models.RetourMagasin</class>
        <class>models.LigneVente</class>
        <class>models.Permission</class>
        <class>models.Vente</class>
        <class>models.Stocker</class>
        <class>models.Journal</class>
        <class>models.PrixDeVente</class>
        <class>models.Produit</class>
        <class>models.Category</class>
        <class>models.CompteTresor</class>
        <class>models.Aretirer</class>
        <class>models.Livraison</class>
        <class>models.User</class>
        <class>models.Client</class>
        <class>models.Taxe</class>
        <class>models.ClientOrganisation</class>
        <class>models.Recquisition</class>
        <class>models.ClientAppartenir</class>
        <class>models.Traisorerie</class>
        <class>models.RetourDepot</class>
        <class>models.Fournisseur</class>
        <class>models.Depense</class>
        <class>models.Affecter</class>
        <class>models.Taxer</class>
        <class>models.Mesure</class>
        <properties>
            <property name="jakarta.persistence.schema-generation.create-database-schemas" value="true"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            
            <property name="hibernate.hikari.maximumPoolSize" value="50" />
            <property name="hibernate.hikari.connectionTimeout" value="30000" />
            <property name="hibernate.hikari.idleTimeout" value="600000" />
            <property name="hibernate.hikari.maxLifetime" value="1800000" />
        </properties>
    </persistence-unit>
</persistence>
